# Database — SQLite by default, no setup needed
# To use PostgreSQL: postgresql://user:pass@localhost:5432/assetmgmt
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Optional: LLM API keys for screenshot → holdings extraction
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App security (change if exposing beyond localhost)
SECRET_KEY=change-me-in-production
